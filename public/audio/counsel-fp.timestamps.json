{
  "file": "public/audio/counsel-fp.wav",
  "segments": [
    {
      "start": 0.0,
      "end": 3.119999885559082,
      "text": " 맞아요. 당장 급하지 않으니까요."
    },
    {
      "start": 3.259999990463257,
      "end": 4.820000171661377,
      "text": " 저도 억지로 권하고 싶지 않아요."
    },
    {
      "start": 5.599999904632568,
      "end": 6.340000152587891,
      "text": " 다음에 하셔도 됩니다."
    },
    {
      "start": 7.099999904632568,
      "end": 9.920000076293945,
      "text": " 근데 다음에 하면 딱 두 가지가 달라집니다."
    },
    {
      "start": 10.800000190734863,
      "end": 13.880000114440918,
      "text": " 첫째, 고객님은 내일이면 하루 더 나이 드세요."
    },
    {
      "start": 14.800000190734863,
      "end": 19.079999923706055,
      "text": " 둘째, 그 사이에 병원 한 번이라도 다녀오시거나 건강검진하시면"
    },
    {
      "start": 19.079999923706055,
      "end": 22.360000610351562,
      "text": " 이 조건 그대로는 다시 가입 못하실 수 있어요."
    },
    {
      "start": 23.360000610351562,
      "end": 26.219999313354492,
      "text": " 보험은 돈으로 사는 게 아니라 건강으로 사는 거예요."
    },
    {
      "start": 26.219999313354492,
      "end": 30.540000915527344,
      "text": " 가장 건강하고 저렴한 오늘이 가장 좋은 조건입니다."
    }
  ],
