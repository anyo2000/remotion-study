{
  "file": "public/audio/link-edu-ep02-familiar.wav",
  "segments": [
    {
      "start": 0.0,
      "end": 1.4199999570846558,
      "text": " 첫 통화에서 고객이"
    },
    {
      "start": 1.4199999570846558,
      "end": 2.700000047683716,
      "text": " 아, 관심 없어요"
    },
    {
      "start": 2.700000047683716,
      "end": 4.300000190734863,
      "text": " 하고 전화를 끊어요"
    },
    {
      "start": 4.300000190734863,
      "end": 5.21999979019165,
      "text": " 그 고객"
    },
    {
      "start": 5.21999979019165,
      "end": 7.380000114440918,
      "text": " 이제 영영 못 만나요"
    },
    {
      "start": 7.619999885559082,
      "end": 9.640000343322754,
      "text": " SFP, FP님들"
    },
    {
      "start": 9.640000343322754,
      "end": 12.960000038146973,
      "text": " 또는 이관받은 고객과 첫 통화하는 FP님들이"
    },
    {
      "start": 12.960000038146973,
      "end": 14.880000114440918,
      "text": " 매일 겪는 상황이에요"
    },
    {
      "start": 14.880000114440918,
      "end": 16.81999969482422,
      "text": " 얼굴도 못 본 고객이랑"
    },
    {
      "start": 16.81999969482422,
      "end": 19.020000457763672,
      "text": " 통화 한 번으로 약속을 잡아야 하거든요"
    },
    {
      "start": 19.719999313354492,
      "end": 22.1200008392334,
      "text": " 첫 통화가 마지막 통화가 될 수 있어요"
    },
    {
      "start": 22.760000228881836,
      "end": 23.600000381469727,
      "text": " 친해질 시간?"
    },
    {
      "start": 24.18000030517578,
      "end": 24.479999542236328,
      "text": " 없어요"
    },
    {
      "start": 24.479999542236328,
      "end": 26.100000381469727,
      "text": " 선물 들고 갈 기회?"
    },
    {
      "start": 26.739999771118164,
      "end": 27.200000762939453,
      "text": " 없어요"
    },
    {
      "start": 27.399999618530273,
      "end": 29.200000762939453,
      "text": " 이관받았다고 인사할 기회?"
    },
    {
      "start": 29.200000762939453,
      "end": 30.0,
      "text": " 없어요"
    },
    {
      "start": 30.760000228881836,
      "end": 32.0,
      "text": " 근데 FP 여러분"
    },
    {
      "start": 32.0,
      "end": 34.91999816894531,
      "text": " 이게 SFP만의 얘기일까요?"
    },
    {
      "start": 35.2599983215332,
      "end": 37.619998931884766,
      "text": " 여러 회사 비교 판매하는 어떤 회사에서"
    },
    {
      "start": 37.619998931884766,
      "end": 39.29999923706055,
      "text": " 이런 회의가 있었다고 해요"
    },
    {
      "start": 39.29999923706055,
      "end": 43.47999954223633,
      "text": " 10년 안에 우리나라 FP의 절반이 없어질 거다"
    },
    {
      "start": 43.47999954223633,
      "end": 44.279998779296875,
      "text": " 왜 그럴까요?"
    },
    {
      "start": 45.18000030517578,
      "end": 45.84000015258789,
      "text": " 생각해 보세요"
    },
    {
      "start": 45.84000015258789,
      "end": 47.20000076293945,
      "text": " 가장 싸고"
    },
    {
      "start": 47.20000076293945,
      "end": 48.47999954223633,
      "text": " 가장 혜택 좋고"
    },
    {
      "start": 48.47999954223633,
      "end": 51.0,
      "text": " 가입 쉬운 상품 찾아서 추천해 주는 거"
    },
    {
      "start": 51.0,
      "end": 52.619998931884766,
      "text": " 이거 누가 제일 잘할까요?"
    },
    {
      "start": 53.2599983215332,
      "end": 53.880001068115234,
      "text": " AI예요"
    },
    {
      "start": 53.880001068115234,
      "end": 56.36000061035156,
      "text": " 사람이 AI 이길 수가 없어요"
    },
    {
      "start": 56.36000061035156,
      "end": 58.70000076293945,
      "text": " 여러 회사 상품을 싹 비교해서"
    },
    {
      "start": 58.70000076293945,
      "end": 60.7400016784668,
      "text": " 고객한테 맞는 걸 뽑는 거"
    },
    {
      "start": 60.7400016784668,
      "end": 62.34000015258789,
      "text": " 컴퓨터가 1초만에 해요"
    },
    {
      "start": 62.36000061035156,
      "end": 65.55999755859375,
      "text": " 그래서 GA의 장점이 없어질 거라는 거예요"
    },
    {
      "start": 66.13999938964844,
      "end": 69.0199966430664,
      "text": " 그럼 우리 전속 FP는 뭐로 먹고 살아야 할까요?"
    },
    {
      "start": 69.91999816894531,
      "end": 70.86000061035156,
      "text": " 딱 하나 남아요"
    },
    {
      "start": 70.86000061035156,
      "end": 71.68000030517578,
      "text": " 관계예요"
    },
    {
      "start": 72.26000213623047,
      "end": 74.81999969482422,
      "text": " 이 사람은 내가 가장 잘 아는 사람이다"
    },
    {
      "start": 74.81999969482422,
      "end": 77.08000183105469,
      "text": " 이 고객 가족 구성원이 어떤지"
    },
    {
      "start": 77.08000183105469,
      "end": 79.13999938964844,
      "text": " 이 고객 성향이 어떤지"
    },
    {
      "start": 79.13999938964844,
      "end": 81.19999694824219,
      "text": " 최근에 어떤 걱정을 하고 있는지"
    },
    {
      "start": 81.19999694824219,
      "end": 83.23999786376953,
      "text": " 이건 컴퓨터로 못 찾거든요"
    },
    {
      "start": 83.23999786376953,
      "end": 85.31999969482422,
      "text": " 우리가 아는 거예요"
    },
    {
      "start": 85.31999969482422,
      "end": 87.5999984741211,
      "text": " 그래서 우리가 순서를 바꾸기로 한 거예요"
    },
    {
      "start": 88.12000274658203,
      "end": 89.4000015258789,
      "text": " 관계가 먼저 있고"
    },
    {
      "start": 89.4000015258789,
      "end": 91.76000213623047,
      "text": " 전문성이 따라오던 시대는 갔으니까"
    },
    {
      "start": 91.77999877929688,
      "end": 94.23999786376953,
      "text": " 이제는 전문성을 먼저 보여주고"
    },
    {
      "start": 94.23999786376953,
      "end": 95.66000366210938,
      "text": " 관계가 따라오게"
    },
    {
      "start": 95.66000366210938,
      "end": 99.18000030517578,
      "text": " 이 순서를 바꾸는 일이 지금 시대에 맞는 답이에요"
    },
    {
      "start": 99.80000305175781,
      "end": 100.94000244140625,
      "text": " 그리고 FP 여러분"
    },
    {
      "start": 100.94000244140625,
      "end": 102.95999908447266,
      "text": " 진짜 역설 하나 알려드릴게요"
    },
    {
      "start": 103.5199966430664,
      "end": 105.81999969482422,
      "text": " 요즘 보험이 이렇게 복잡해진 거"
    },
    {
      "start": 105.81999969482422,
      "end": 107.95999908447266,
      "text": " 저는 오히려 우리한테 기회라고 봐요"
    },
    {
      "start": 108.5999984741211,
      "end": 110.91999816894531,
      "text": " 보험이 예전처럼 단순했으면요"
    },
    {
      "start": 110.91999816894531,
      "end": 113.04000091552734,
      "text": " 우리가 할 일은 벌써 없어졌어요"
    },
    {
      "start": 113.04000091552734,
      "end": 115.4800033569336,
      "text": " 다이렉트로 가입하면 되니까요"
    },
    {
      "start": 115.4800033569336,
      "end": 118.08000183105469,
      "text": " 근데 지금은 종합형 담보가 200개"
    },
    {
      "start": 118.08000183105469,
      "end": 120.26000213623047,
      "text": " 암 담보만 해도 30개예요"
    },
    {
      "start": 120.26000213623047,
      "end": 123.63999938964844,
      "text": " 너무 복잡하니까 고객이 우리한테 물어보는 거예요"
    },
    {
      "start": 123.63999938964844,
      "end": 125.54000091552734,
      "text": " 이건 뭐가 달라요?"
    },
    {
      "start": 125.83999633789062,
      "end": 126.87999725341797,
      "text": " 저한테 왜 필요해요?"
    },
    {
      "start": 127.4000015258789,
      "end": 129.9600067138672,
      "text": " 이 질문 하나가 우리한테 남은 기회거든요"
    },
    {
      "start": 129.9600067138672,
      "end": 132.0800018310547,
      "text": " 단, 조건이 있어요"
    },
    {
      "start": 132.0800018310547,
      "end": 135.9600067138672,
      "text": " 우리가 예전 교육받을 때는 15분이 기본이었어요"
    },
    {
      "start": 135.9600067138672,
      "end": 138.0800018310547,
      "text": " 보장 분석 15분 안에 못 끝내잖아"
    },
    {
      "start": 138.0800018310547,
      "end": 139.5800018310547,
      "text": " 이 사람 안 들어줘"
    },
    {
      "start": 139.5800018310547,
      "end": 140.5,
      "text": " 이렇게 배웠죠"
    },
    {
      "start": 140.5,
      "end": 142.25999450683594,
      "text": " 근데 요즘은요"
    },
    {
      "start": 142.25999450683594,
      "end": 142.75999450683594,
      "text": " 15분?"
    },
    {
      "start": 143.4600067138672,
      "end": 144.05999755859375,
      "text": " FP 여러분"
    },
    {
      "start": 144.05999755859375,
      "end": 147.05999755859375,
      "text": " 15분 시간 내달라고 하기 진짜 힘들어요"
    },
    {
      "start": 147.0800018310547,
      "end": 148.6199951171875,
      "text": " 5분도 어려워요"
    },
    {
      "start": 148.6199951171875,
      "end": 151.02000427246094,
      "text": " 1분 안에 이 사람 관심 못 잡으면"
    },
    {
      "start": 151.02000427246094,
      "end": 152.60000610351562,
      "text": " 그날은 진행이 안 돼요"
    },
    {
      "start": 153.17999267578125,
      "end": 153.97999572753906,
      "text": " 정리할게요"
    },
    {
      "start": 154.22000122070312,
      "end": 156.75999450683594,
      "text": " AI가 못 주는 걸 우리가 줘야 하고"
    },
    {
      "start": 156.75999450683594,
      "end": 158.9600067138672,
      "text": " 복잡한 걸 쉽게 풀어줘야 하고"
    },
    {
      "start": 158.9600067138672,
      "end": 161.05999755859375,
      "text": " 그걸 1분 안에 해내야 해요"
    },
    {
      "start": 161.05999755859375,
      "end": 162.39999389648438,
      "text": " 이게 가능할까요?"
    },
    {
      "start": 163.1999969482422,
      "end": 163.52000427246094,
      "text": " 가능해요"
    },
    {
      "start": 163.83999633789062,
      "end": 165.44000244140625,
      "text": " 방법이 있으니까요"
    },
    {
      "start": 165.44000244140625,
      "end": 167.86000061035156,
      "text": " 다음 편에서 L, I, N, K"
    },
    {
      "start": 167.86000061035156,
      "end": 170.82000732421875,
      "text": " 네 글자의 전체 지도를 펼쳐서 설명해 드릴게요"
    }
  ],
